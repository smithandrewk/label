# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=smoking_app
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=smoking_data

# Data Directory (where project files will be stored)
# For shared setup with beast server, keep this path as is
DATA_DIR=~/.delta/data

# Beast server configuration
# Your username on the beast server for SSHFS mounting
BEAST_USERNAME=your_username

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
