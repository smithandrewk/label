# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=smoking_app
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=smoking_data

# Data Directory (where project files will be stored)
DATA_DIR=~/.delta/data
MODEL_DIR=~/.delta/models


# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true

# Logging Configuration
LOG_LEVEL=INFO

# Redis Configuration (optional - for improved remote performance)
# If Redis is not available, caching will be disabled gracefully
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password_here
# Leave REDIS_PASSWORD empty or comment it out if Redis has no password
